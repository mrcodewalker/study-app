<?xml version="1.0" encoding="utf-8"?>
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <aapt:attr name="android:drawable">
        <vector
            android:width="108dp"
            android:height="108dp"
            android:viewportWidth="108"
            android:viewportHeight="108">

            <!-- Book icon group — centered, will be animated -->
            <group
                android:name="bookGroup"
                android:pivotX="54"
                android:pivotY="54"
                android:scaleX="0.1"
                android:scaleY="0.1"
                android:translateY="10">

                <!-- Book body left page -->
                <path
                    android:name="leftPage"
                    android:fillColor="#3F665C"
                    android:pathData="M54,28 C54,28 36,30 30,36 L30,78 C30,78 42,74 54,76 Z" />

                <!-- Book body right page -->
                <path
                    android:name="rightPage"
                    android:fillColor="#5E5B7A"
                    android:pathData="M54,28 C54,28 72,30 78,36 L78,78 C78,78 66,74 54,76 Z" />

                <!-- Book spine -->
                <path
                    android:name="spine"
                    android:fillColor="#274E45"
                    android:pathData="M52,28 L56,28 L56,76 L52,76 Z" />

                <!-- Lines on left page -->
                <path
                    android:fillColor="#B8E2D6"
                    android:pathData="M36,44 L50,42 M36,50 L50,48 M36,56 L50,54 M36,62 L50,60"
                    android:strokeColor="#B8E2D6"
                    android:strokeWidth="1.5"
                    android:strokeLineCap="round" />

                <!-- Lines on right page -->
                <path
                    android:fillColor="#DED9FD"
                    android:pathData="M58,42 L72,44 M58,48 L72,50 M58,54 L72,56 M58,60 L72,62"
                    android:strokeColor="#DED9FD"
                    android:strokeWidth="1.5"
                    android:strokeLineCap="round" />

                <!-- Sparkle top-right -->
                <path
                    android:name="sparkle"
                    android:fillColor="#B8860B"
                    android:pathData="M76,22 L77.5,26 L82,27.5 L77.5,29 L76,33 L74.5,29 L70,27.5 L74.5,26 Z" />

            </group>
        </vector>
    </aapt:attr>

    <!-- Animate scale X: 0.1 → 1.2 → 1.0 (bounce) -->
    <target android:name="bookGroup">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0.1"
                    android:valueTo="1.2"
                    android:duration="450"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0.1"
                    android:valueTo="1.2"
                    android:duration="450"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator
                    android:propertyName="translateY"
                    android:valueFrom="10"
                    android:valueTo="-6"
                    android:duration="450"
                    android:interpolator="@android:interpolator/overshoot" />
            </set>
        </aapt:attr>
    </target>

</animated-vector>
